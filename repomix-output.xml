import React from 'react';
import './PersonModal.css';

function PersonModal({ person, onClose, onDelete }) {
  return (
    <div className="modal-overlay" onClick={onClose}>
      <div
        className="modal-content"
        onClick={(e) => e.stopPropagation()} // клік всередині не закриває
      >
        <span className="modal-close" onClick={onClose}>&times;</span>

        <h2>{person.lastName} {person.firstName} {person.patronymic}</h2>
        <p>Рік народження: {person.birthYear || '—'}</p>

        {person.notes && (
          <p className="modal-notes">{person.notes}</p>
        )}

        <button
          className="modal-delete-btn"
          onClick={() => onDelete(person.id)}
        >
          Видалити
        </button>
      </div>
    </div>
  );
}

export default PersonModal;
